# Create a .env file locally or set these values in your hosting provider.
TELEGRAM_BOT_TOKEN=replace_with_a_new_token_from_botfather
# Optional: comma-separated Telegram user IDs. Leave empty to allow everyone.
ALLOWED_USER_IDS=
# Your own Telegram ID. Only this account can use /addid and /deleteid.
ADMIN_USER_IDS=
# Optional: interval for market checks in seconds (minimum 10).
CHECK_INTERVAL_SECONDS=30
